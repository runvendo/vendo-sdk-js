{
  "name": "@vendodev/sdk",
  "version": "0.1.0",
  "description": "Vendo platform SDK — fetch fresh OAuth credentials inside Vendo deployments",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runvendo/vendo-sdk-js.git"
  },
  "homepage": "https://vendo.run",
  "bugs": "https://github.com/runvendo/vendo-sdk-js/issues",
  "keywords": ["vendo", "oauth", "credentials", "google", "notion"],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
