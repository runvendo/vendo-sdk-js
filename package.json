{
  "name": "@vendodev/sdk",
  "version": "0.5.3",
  "description": "Vendo TypeScript SDK — runtime contract for apps deployed via Vendo",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "jsdelivr": "dist/browser/index.js",
  "unpkg": "dist/browser/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./browser": {
      "import": {
        "types": "./dist/browser/index.d.ts",
        "default": "./dist/browser/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runvendo/vendo-sdk-js.git"
  },
  "homepage": "https://vendo.run",
  "bugs": "https://github.com/runvendo/vendo-sdk-js/issues",
  "keywords": [
    "vendo",
    "sdk",
    "oauth",
    "credentials",
    "deployment"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "happy-dom": "^20.9.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "yaml": "^2.8.4"
  },
  "dependencies": {}
}
